# Servidor
NODE_ENV=development
PORT=3000

# Banco de dados (Postgres — use o docker-compose ou uma instância local)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_system?schema=public"

# JWT (access token)
JWT_ACCESS_SECRET=troque-por-um-segredo-forte-aleatorio
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token (opaco, armazenado com hash no banco, entregue via cookie httpOnly)
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

# CORS — origem do seu frontend (precisa bater com o domínio real por causa do cookie)
CORS_ORIGIN=http://localhost:5173

# Rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=100

# Usuário admin criado pelo script de seed (npm run prisma:seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@12345
